@page "/expenses"
@using DemoFluentUI.Services
@inject ExpenseService Service

<PageTitle>Expenses</PageTitle>

<FluentMultiSplitter Height="var(--layout-body-height)" Width="100%" Padding="@Padding.All2">

    @* Panel "New Expense" *@
    <FluentMultiSplitterPane Size="40%" Min="320px" Padding="@Padding.All2">
            
        <FluentText Size="TextSize.Size600">New Expense</FluentText>

        @* Edit Expense Panel *@
        <EditExpenseDialog Item="CurrentExpense" />
            
    </FluentMultiSplitterPane>

    @* Panel "Expenses List" *@
    <FluentMultiSplitterPane>
        @foreach (var item in Service.Items)
        {
            <FluentCard Style="padding: 12px;">
                <FluentStack Orientation="Orientation.Horizontal"
                            VerticalAlignment="VerticalAlignment.Center"
                            HorizontalGap="12">
                    <FluentIcon Value="@(new Icons.Filled.Size24.Circle())"
                                Color="@Color.Custom"
                                CustomColor="@item.Color" />

                    <FluentStack Orientation="Orientation.Vertical"
                                VerticalGap="2px"
                                Width="unset">
                        <FluentText>@item.Description</FluentText>
                        <FluentText Color="@Color.Info"">
                            @item.Date?.ToShortDateString() · @item.Category
                        </FluentText>
                    </FluentStack>

                    <FluentSpacer />

                    <FluentText Nowrap>@($"{item.Amount} €")</FluentText>                    
                </FluentStack>
            </FluentCard>
        }

    </FluentMultiSplitterPane>
</FluentMultiSplitter>

@code
{
    private Expense CurrentExpense = new();

    override protected void OnInitialized() => Service.Changed += StateHasChanged;
}