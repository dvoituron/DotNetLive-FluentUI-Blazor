@page "/expenses"
@using DemoFluentUI.Services
@inject ExpenseService Service
@inject IDialogService DialogService

<PageTitle>Expenses</PageTitle>

<FluentMultiSplitter Height="var(--layout-body-height)" Width="100%" Padding="@Padding.All2">

    @* Panel "New Expense" *@
    @*
    <FluentMultiSplitterPane Size="40%" Min="320px" Padding="@Padding.All2">
            
        <FluentText Size="TextSize.Size600">New Expense</FluentText>
        <EditExpenseDialog Item="CurrentExpense" />
            
    </FluentMultiSplitterPane>
    *@

    @* Panel "Expenses List" *@
    <FluentMultiSplitterPane Padding="@Padding.All2">

        @* Toolbar  *@
        <FluentStack Padding="@Padding.Vertical2" HorizontalAlignment="HorizontalAlignment.End">

            <FluentButton IconStart="@(new Icons.Regular.Size20.Add())"
                          OnClick="@(e => OpenEditAsync(new Expense()))">
                Add
            </FluentButton>
            <FluentSpacer />

            <FluentButton Id="importCsvButton"
                            IconStart="@(new Icons.Regular.Size20.ArrowImport())">
                Import CSV
            </FluentButton>
        </FluentStack>

        <FluentDataGrid TGridItem="Expense"
                        Items="@Service.Items.AsQueryable()"
                        ResizableColumns="true">

            <!-- Description -->
            <TemplateColumn Title="Description" 
                            Sortable="true" 
                            SortBy="@(GridSort<Expense>.ByAscending(e => e.Description))">
                <FluentStack>
                    <FluentIcon Value="@(new Icons.Filled.Size20.Circle())"
                                Margin="@Margin.Right3"
                                Color="@Color.Custom"
                                CustomColor="@context.Color" />
                    <FluentText>@context.Description</FluentText>
                </FluentStack>
            </TemplateColumn>

            <!-- Date, Category, Amount -->
            <PropertyColumn TGridItem="Expense" 
                            TProp="DateTime?"
                            Title="Date"
                            Property="@(e => e.Date)"
                            Format="d"
                            Sortable="true"
                            Width="120px" />

            <PropertyColumn TGridItem="Expense" 
                            TProp="Expense.Categories"
                            Title="Category"
                            Property="@(e => e.Category)"
                            Sortable="true"
                            Width="140px" />

            <PropertyColumn TGridItem="Expense" 
                            TProp="decimal"
                            Title="Amount"
                            Property="@(e => e.Amount)"
                            Format="C2"
                            Align="DataGridCellAlignment.End"
                            Sortable="true"
                            Width="120px" />

            <!-- Actions: Edit / Delete -->
            <TemplateColumn Title="Actions"
                            Align="DataGridCellAlignment.End"
                            Width="120px">
                <FluentButton IconStart="@(new Icons.Regular.Size20.Edit())"
                              OnClick="@(() => OpenEditAsync(context))"
                              Title="Edit" />                              
                <FluentButton IconStart="@(new Icons.Regular.Size20.Delete())"
                              OnClick="@(() => DeleteAsync(context))"
                              Title="Delete" />
            </TemplateColumn>
        </FluentDataGrid>

    </FluentMultiSplitterPane>
</FluentMultiSplitter>

@code
{
    private Expense CurrentExpense = new();

    override protected void OnInitialized() => Service.Changed += StateHasChanged;

    override protected Task OnInitializedAsync()
    {
        return DialogService.RegisterInputFileAsync("importCsvButton", OnImportCompletedAsync, 
            options => 
            {
                options.Accept = ".csv";
                options.Multiple = false;
            });     
    }

    private async Task OnImportCompletedAsync(IEnumerable<FluentInputFileEventArgs> files)
    {
        foreach (var file in files)
        {
            if (file.LocalFile is { } local)
            {
                await using var stream = local.OpenRead();
                Service.ImportCsv(stream);
                local.Delete();
            }
        }
    }

    private async Task DeleteAsync(Expense item)
    {
        var result = await DialogService.ShowConfirmationAsync(
                            message: $"Delete '{item.Description}'?", 
                            title: "Confirm deletion", 
                            primaryButton: "Delete", 
                            secondaryButton: "Cancel");

        if (!result.Cancelled)
        {
            Service.Remove(item.Id);
        }
    }

    private async Task OpenEditAsync(Expense item)
    {
        var result = await DialogService.ShowDialogAsync<EditExpenseDialog>(options =>
        {
            options.Parameters.Add(nameof(EditExpenseDialog.Item), item.Clone());
            options.Header.CloseAction.Visible = true;
            options.Alignment = DialogAlignment.End;
        });

        if (!result.Cancelled && result.Value is Expense updated)
        {
            Service.Update(updated);
        }
    }

    private async Task OpenImportAsync()
    {
        await Task.CompletedTask;
    }
}